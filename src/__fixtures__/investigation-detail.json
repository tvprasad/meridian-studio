  "analysis": {
    "summary": "12 settlement records with valid merchant_id were skipped by ETL due to a NULL check on a different field (processor_code). The ETL logic incorrectly treats NULL processor_code as invalid, but these records use a legacy format where processor_code is not populated.",
    "root_cause_hypothesis": "ETL WHERE clause filters out records where processor_code IS NULL, but legacy merchant records (pre-2025) do not populate this field. The filter was added in ETL v3.2 without accounting for legacy records.",
    "confidence": 0.87,
    "confidence_rationale": "Three independent data sources confirm the same 12-record gap. The ETL log explicitly shows 12 skipped records matching the delta.",
    "supporting_evidence": ["F-001", "F-002", "F-003"],
    "contradicting_evidence": [],
    "gaps": ["ETL v3.2 changelog not reviewed — filter change may have been intentional"],
    "severity": "high",
    "affected_systems": ["payments_etl", "settlement_reporting"],
    "time_range": "2026-03-19 batch"
  },
  "policy_decision": {
    "action_recommended": true,
    "rationale": "The 12 skipped records are legitimate settlement entries. Modifying the ETL filter to allow NULL processor_code for legacy merchants will restore the correct totals. The fix is bounded to the WHERE clause and affects only future runs.",
    "execution_plan": {
      "plan_id": "PLAN-OPS-1234-001",
      "plan_hash": "sha256:e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3",
      "action_summary": "Update ETL filter to permit NULL processor_code for legacy merchants, then re-run the 2026-03-19 batch.",
      "steps": [
        {
          "step_number": 1,
          "action": "Update ETL WHERE clause to allow NULL processor_code",
          "tool": "db_write",
          "target": "etl_config.filter_rules",
          "parameters": {"rule_id": "merchant_validation", "field": "processor_code", "allow_null": true, "condition": "merchant_created_before='2025-01-01'"},
          "precondition": "Current filter_rules row exists with allow_null=false",
          "expected_outcome": "1 row updated",
          "rollback_command": "UPDATE etl_config.filter_rules SET allow_null=false WHERE rule_id='merchant_validation'"
        },
        {
          "step_number": 2,
          "action": "Re-run ETL for 2026-03-19 batch",
          "tool": "api_mutate",
          "target": "etl_scheduler",
          "parameters": {"batch_date": "2026-03-19", "mode": "reprocess"},
          "precondition": "No ETL run currently in progress",
          "expected_outcome": "Batch reprocessed with 45,243 records (12 more than previous run)",
          "rollback_command": "POST /etl/cancel?batch=2026-03-19"
        }
      ],
      "total_steps": 2,
      "blast_radius": "medium",
      "blast_radius_detail": "Affects ETL filter configuration and triggers a batch reprocess. No impact on live transaction flow.",
      "reversible": true,
      "evidence_refs": ["F-001", "F-002", "F-003"],
      "estimated_duration_s": 120
    },
    "risk_score": 0.35,
